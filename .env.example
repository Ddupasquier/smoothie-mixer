# FoodData Central API key
# Get your free API key at: https://fdc.nal.usda.gov/api-guide.html
VITE_FDC_API_KEY=

# Supabase public browser keys
# Safe to expose in the client. Security comes from Supabase Auth + RLS policies.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Canonical deployed app origin used for authentication callbacks.
# Local development can leave this empty and will use http://localhost:5173.
PUBLIC_SITE_URL=
