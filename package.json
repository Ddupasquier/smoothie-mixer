{
	"name": "smoothie-mixer",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host localhost --port 5173 --strictPort",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"audit:fdc-vitals": "node scripts/audit_fdc_vitals.mjs",
		"compare:fdc": "node scripts/compare_fdc_products.mjs",
		"discover:fdc-nutrients": "node scripts/discover_fdc_nutrients.mjs",
		"test": "vitest run",
		"test:watch": "vitest",
		"kill:vite": "pkill -f \"node .*node_modules/.bin/vite dev\" 2>/dev/null || true",
		"free:dev-port": "pids=$(lsof -ti :5173 2>/dev/null); if [ -n \"$pids\" ]; then kill -9 $pids; fi",
		"predev": "npm run kill:vite && npm run free:dev-port",
		"supabase": "supabase",
		"db:link": "supabase link --project-ref wbqsnipoiqjzppjuawpn",
		"db:new": "supabase migration new",
		"db:push": "supabase db push",
		"db:types": "mkdir -p src/lib/types && supabase gen types typescript --linked > src/lib/types/database.types.ts",
		"db:push:dry": "supabase db push --dry-run"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.9.1",
		"@types/ws": "^8.18.1",
		"jsdom": "^29.1.1",
		"sass": "^1.100.0",
		"supabase": "^2.105.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.7"
	},
	"dependencies": {
		"@supabase/ssr": "^0.10.3",
		"@supabase/supabase-js": "^2.107.0",
		"@vercel/speed-insights": "^2.0.0",
		"dotenv": "^17.4.2",
		"node-fetch": "^3.3.2",
		"ws": "^8.21.0"
	}
}
